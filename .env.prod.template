# ═══════════════════════════════════════════════════════════════
# Shadow Deploy — Production Environment Variables
# Copy this file to .env.prod and fill in all values.
# Usage: docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.prod up -d
# ═══════════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────────
POSTGRES_USER=shadow
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ─── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password

# ─── JWT Secret (min 256-bit / 32 chars) ─────────────────────
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64

# ─── Internal Shared Secret (NGINX ↔ Ingestion) ─────────────
INTERNAL_SHARED_SECRET=CHANGE_ME_random_secret_here

# ─── AI Service ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
LLM_PROVIDER=gemini

# ─── Target Application Backends ────────────────────────────
PROD_BACKEND_HOST=your-production-api.example.com
PROD_BACKEND_PORT=443
SHADOW_BACKEND_HOST=your-shadow-api.example.com
SHADOW_BACKEND_PORT=443

# ─── Traffic Mirroring ──────────────────────────────────────
MIRROR_PERCENTAGE=10

# ─── CORS ────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://dashboard.yourdomain.com

# ─── Dashboard Build Args ───────────────────────────────────
VITE_API_URL=https://api.yourdomain.com
