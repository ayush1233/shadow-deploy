{
    "id": null,
    "uid": "shadow-api-overview",
    "title": "Shadow API Validation - Overview",
    "tags": [
        "shadow-api",
        "validation"
    ],
    "timezone": "browser",
    "refresh": "10s",
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "panels": [
        {
            "id": 1,
            "title": "Requests Processed / min",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 0,
                "y": 0
            },
            "targets": [
                {
                    "expr": "rate(shadow_requests_total[1m])",
                    "legendFormat": "req/min"
                }
            ]
        },
        {
            "id": 2,
            "title": "Mismatch Rate",
            "type": "gauge",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 6,
                "y": 0
            },
            "targets": [
                {
                    "expr": "shadow_mismatch_rate",
                    "legendFormat": "mismatch %"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "max": 100,
                    "min": 0,
                    "unit": "percent"
                }
            }
        },
        {
            "id": 3,
            "title": "Deployment Risk Score",
            "type": "gauge",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 12,
                "y": 0
            },
            "targets": [
                {
                    "expr": "shadow_deployment_risk_score",
                    "legendFormat": "risk"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "max": 10,
                    "min": 0
                }
            }
        },
        {
            "id": 4,
            "title": "Critical Mismatches",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 18,
                "y": 0
            },
            "targets": [
                {
                    "expr": "shadow_critical_mismatches_total",
                    "legendFormat": "critical"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": 0
                            },
                            {
                                "color": "red",
                                "value": 1
                            }
                        ]
                    }
                }
            }
        },
        {
            "id": 5,
            "title": "Latency Comparison (p95)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 4
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.95, rate(shadow_prod_latency_bucket[5m]))",
                    "legendFormat": "Production p95"
                },
                {
                    "expr": "histogram_quantile(0.95, rate(shadow_shadow_latency_bucket[5m]))",
                    "legendFormat": "Shadow p95"
                }
            ]
        },
        {
            "id": 6,
            "title": "Severity Distribution",
            "type": "piechart",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 4
            },
            "targets": [
                {
                    "expr": "shadow_mismatches_by_severity",
                    "legendFormat": "{{severity}}"
                }
            ]
        },
        {
            "id": 7,
            "title": "Top Mismatched Endpoints",
            "type": "table",
            "gridPos": {
                "h": 8,
                "w": 24,
                "x": 0,
                "y": 12
            },
            "targets": [
                {
                    "expr": "topk(10, shadow_endpoint_mismatch_count)",
                    "legendFormat": "{{endpoint}}",
                    "format": "table",
                    "instant": true
                }
            ]
        }
    ]
}