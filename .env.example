# ═══════════════════════════════════════════════
# Shadow Deploy Platform — Environment Variables
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Supabase Configuration ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_DB_PASSWORD=your-supabase-db-password

# ── AI / LLM Provider ──
# LLM_PROVIDER: "gemini" | "ollama" | "" (auto-detect: Gemini if key set, else Ollama if running)
LLM_PROVIDER=
GEMINI_API_KEY=your-gemini-api-key

# ── Ollama (local LLM — enable with: docker compose --profile ollama up) ──
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.1

# ── Service Ports (defaults shown, change if ports conflict) ──
DASHBOARD_PORT=3004
NGINX_PROXY_PORT=80
API_SERVICE_PORT=8083
AI_SERVICE_PORT=8000
INGESTION_PORT=8081
COMPARISON_PORT=8082
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090

# ── Target Application Backends ──
# These point to the V1 (production) and V2 (shadow) versions of YOUR app.
# Use 'host.docker.internal' to reach services running on your host machine.
PROD_BACKEND_HOST=host.docker.internal
PROD_BACKEND_PORT=5001
SHADOW_BACKEND_HOST=host.docker.internal
SHADOW_BACKEND_PORT=5002

# ── Traffic Mirroring ──
# Percentage of traffic to mirror to the shadow backend (0-100)
MIRROR_PERCENTAGE=100

# ── Kafka ──
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379

# ── Security ──
# IMPORTANT: Set a strong secret in production (min 256 bits). Do NOT use the default.
JWT_SECRET=
# Comma-separated allowed CORS origins. Add your production dashboard domain.
CORS_ALLOWED_ORIGINS=http://localhost:3004,http://localhost:3000

# ── Notifications ──
SLACK_WEBHOOK_URL=
ALERT_RISK_THRESHOLD=7.0
ALERT_EMAIL_SMTP_HOST=
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
